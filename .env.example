# G-HRMS backend environment template.
# Copy to `.env` and fill in real values. NEVER commit the real `.env`.
#   cp .env.example .env

# ── Core ──────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,testserver
CSRF_TRUSTED_ORIGINS=http://localhost:3000
# Comma-separated reverse-proxy IPs allowed to set X-Forwarded-For (prod only).
TRUSTED_PROXY_IPS=
LOG_LEVEL=INFO

# ── Database (PostgreSQL) ─────────────────────────────────────
DB_NAME=ghrms
DB_USER=ghrms
DB_PASSWORD=change-me
DB_HOST=127.0.0.1
DB_PORT=5432

# ── Cache (Redis in production; leave empty to use in-memory) ──
# Example: redis://127.0.0.1:6379/0
REDIS_URL=

# ── Email / SMTP ──────────────────────────────────────────────
# In DEBUG the default backend prints emails to the console. To actually SEND
# (e.g. via Gmail or an agency relay) you MUST set EMAIL_BACKEND to smtp below.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=youraddress@gmail.com
# 16-char Gmail App Password (2FA required), spaces removed. NOT your login password.
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_TIMEOUT=10
# Must match EMAIL_HOST_USER (or a verified alias) for Gmail.
DEFAULT_FROM_EMAIL=G-HRMS <youraddress@gmail.com>
SERVER_EMAIL=G-HRMS <youraddress@gmail.com>

# ── Authentication / tokens ───────────────────────────────────
AUTH_MAX_FAILED_LOGIN_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15
AUTH_REFRESH_TOKEN_DAYS=7
# AUTH_REFRESH_COOKIE_NAME defaults to __Host-ghrms_refresh outside DEBUG.
AUTH_REFRESH_COOKIE_SAMESITE=Strict
PASETO_PRIVATE_KEY_PATH=.secrets/paseto/private.pem
PASETO_PUBLIC_KEY_PATH=.secrets/paseto/public.pem
PASETO_ISSUER=g-hrms-backend
PASETO_AUDIENCE=g-hrms-api
PASETO_ACCESS_TOKEN_MINUTES=5
PASETO_CLOCK_SKEW_SECONDS=30

# ── Signup OTP / pending-registration policy ──────────────────
AUTH_SIGNUP_OTP_LENGTH=6
AUTH_SIGNUP_OTP_TTL_MINUTES=10
AUTH_SIGNUP_OTP_MAX_ATTEMPTS=5
AUTH_SIGNUP_OTP_RESEND_COOLDOWN_SECONDS=60
AUTH_SIGNUP_OTP_MAX_RESENDS=3
# MX/A email-domain check. Defaults on outside DEBUG; fail-open on DNS errors.
AUTH_SIGNUP_VERIFY_EMAIL_DOMAIN=False
AUTH_SIGNUP_EMAIL_DNS_TIMEOUT=3.0

# ── Throttle rates (DRF), per IP ──────────────────────────────
THROTTLE_SIGNUP=10/min
THROTTLE_SIGNUP_VERIFY=10/min
THROTTLE_SIGNUP_RESEND=5/min

# ── Superadmin seed (python manage.py seed_superadmin) ────────
SUPERADMIN_EMAIL=deulatech@gmail.com
SUPERADMIN_USERNAME=superadmin
# Required to seed. Use a strong password; never commit the real value.
SUPERADMIN_PASSWORD=Ghrms@Sl75qcCBJzBuJ9

